# AgriScan — Environment Variables
# Copy this file to .env and fill in your values.
# In Vercel: add these as Environment Variables in Project Settings.

# ─── Firebase ───────────────────────────────────────────────────────────────
# From Firebase Console → Project Settings → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ─── Google Gemini (optional) ────────────────────────────────────────────────
# From https://aistudio.google.com/app/apikey
# If omitted the app falls back to the built-in 38-class treatment database.
VITE_GEMINI_API_KEY=your_gemini_api_key
